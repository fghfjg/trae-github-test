{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd cpolar-chat && npm install && cd ../frontend && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd cpolar-chat && node index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "numReplicas": 1
  }
}
