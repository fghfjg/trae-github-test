{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --prefix cpolar-chat && npm install --prefix frontend && npm run build --prefix frontend"
  },
  "deploy": {
    "startCommand": "node cpolar-chat/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "numReplicas": 1
  }
}
